          },
          "else_effects": {},
          "reward": 0.2,
          "else_reward": -0.1
        },
        "lock_compromised_accounts": {
          "condition": "compromised_accounts == '3_service_accounts'",
          "effects": {
            "discovered.accounts_locked": true,
            "compromised_accounts": "locked",
            "lateral_movement": "contained"
          },
          "else_effects": {},
          "reward": 0.25,
          "else_reward": -0.2
        },
        "check_mfa_bypass": {
          "condition": "discovered.checked_mfa == false",
          "effects": {
            "discovered.checked_mfa": true,
            "mfa_status": "bypass_detected_on_2_accounts"
          },
          "reward": 0.1,
          "else_reward": -0.05
        },
        "check_api_key_usage": {
          "condition": "discovered.accounts_locked == true AND discovered.checked_api_keys == false",
          "effects": {
            "discovered.checked_api_keys": true,
            "api_keys_status": "2_keys_used_suspiciously"
          },
          "else_effects": {},
          "reward": 0.15,
          "else_reward": -0.1
        },
        "rotate_compromised_keys": {
          "condition": "discovered.checked_api_keys == true AND api_keys_status == '2_keys_used_suspiciously'",
          "effects": {
            "api_keys_status": "rotated_targeted",
            "discovered.keys_rotated": true
          },
          "else_effects": {},
          "reward": 0.25,
          "else_reward": -0.3
        },
        "rotate_all_api_keys": {
          "condition": "1 == 1",
          "effects": {
            "api_keys_status": "all_rotated_outage_triggered"
          },
          "reward": -0.7
        },
        "enable_enhanced_monitoring": {
          "condition": "discovered.keys_rotated == true AND discovered.accounts_locked == true",
          "effects": {
            "incident_contained": true
          },
          "else_effects": {},
          "reward": 0.2,
          "else_reward": -0.05
        }
      },
      "bleed_rules": [
        {"condition": "compromised_accounts == '3_service_accounts'", "penalty": -0.1},
        {"condition": "lateral_movement == 'detected_2_hops'", "penalty": -0.08},
        {"condition": "data_exfiltration == 'completed'", "penalty": -0.5}
      ],
      "sla_rules": {
        "required": [
          "incident_contained == true",
          "discovered.accounts_locked == true",
          "discovered.keys_rotated == true"
        ],
        "forbidden": [
          "api_keys_status == 'all_rotated_outage_triggered'",
          "data_exfiltration == 'completed'"
        ]
      },
      "sla_violation_penalty": -1.5
    }
  ]
}
