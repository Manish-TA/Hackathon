        "enable_enhanced_monitoring",
        "do_nothing"
      ],
      "penalties": {
        "rotate_all_api_keys": -0.7
      },
      "optimal_solution_path": [
        "analyze_login_anomalies",
        "trace_lateral_movement",
        "audit_data_access_logs",
        "lock_compromised_accounts",
        "check_api_key_usage",
        "rotate_compromised_keys",
        "enable_enhanced_monitoring"
      ],
      "transition_rules": {
