      "initial_state": {
        "alert_type": "anomalous_logins",
        "compromised_accounts": "unknown",
        "lateral_movement": "unknown",
        "data_exfiltration": "unknown",
        "mfa_status": "unknown",
        "api_keys_status": "unknown",
        "incident_contained": false,
        "discovered": {
          "analyzed_logins": false,
          "traced_lateral": false,
          "checked_data_access": false,
          "checked_mfa": false,
          "checked_api_keys": false,
          "accounts_locked": false,
          "keys_rotated": false
